<mxfile host="app.diagrams.net">
  <diagram name="Pagină-1" id="ep1i69MkJUoxke0pnXGU">
    <mxGraphModel dx="6867" dy="3747" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="2336" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml class_diagram_a3\n\nskinparam classAttributeIconSize 0\nskinparam packageStyle rectangle\nskinparam linetype polyline\nskinparam nodesep 30\nskinparam ranksep 40\nscale 0.7\n\n&#39; =================== PET SERVICE ===================\npackage \&quot;pet-service\&quot; {\n    class Pet {\n        -id: Integer\n        -name: String\n        -species: String\n        -breed: String\n        -age: Integer\n        -price: BigDecimal\n        -available: boolean\n        -imagePath: String\n    }\n\n    class PetDTO {\n        -id: Integer\n        -name: String\n        -species: String\n        -breed: String\n        -age: Integer\n        -price: BigDecimal\n        +from(pet: Pet): PetDTO\n    }\n\n    class PetRequest {\n        -name: String\n        -species: String\n        -breed: String\n        -age: Integer\n        -price: BigDecimal\n    }\n\n    interface PetRepository {\n        +findByNameContainingIgnoreCase(name): List&lt;Pet&gt;\n        +findAll(sort: Sort): List&lt;Pet&gt;\n    }\n\n    interface PetService {\n        +savePet(request: PetRequest): PetDTO\n        +updatePet(id: Integer, request: PetRequest): PetDTO\n        +deletePetById(id: Integer): void\n        +getAllPets(): List&lt;PetDTO&gt;\n        +getPetById(id: Integer): Optional&lt;PetDTO&gt;\n        +searchAndSort(name, sortField, sortDir): List&lt;PetDTO&gt;\n    }\n\n    class PetServiceClass implements PetService {\n        -petRepository: PetRepository\n        -eventManager: EventManager\n    }\n\n    class PetController {\n        -petService: PetService\n        +getAllPets(): ResponseEntity\n        +getPetById(id): ResponseEntity\n        +createPet(request): ResponseEntity\n        +updatePet(id, request): ResponseEntity\n        +deletePet(id): ResponseEntity\n    }\n\n    PetController --&gt; PetService\n    PetServiceClass --&gt; PetRepository\n}\n\n&#39; =================== ITEM SERVICE ===================\npackage \&quot;item-service\&quot; {\n    class Item {\n        -id: Integer\n        -name: String\n        -description: String\n        -price: double\n        -type: ItemType\n        -imagePath: String\n        -petId: Integer\n    }\n\n    enum ItemType {\n        FOOD\n        TOY\n        ACCESSORY\n    }\n\n    class ItemDTO {\n        -id: Integer\n        -name: String\n        -price: Double\n        -type: String\n        -petId: Integer\n        -petName: String\n        +from(item: Item, petName: String): ItemDTO\n    }\n\n    class ItemRequest {\n        -name: String\n        -description: String\n        -price: double\n        -type: ItemType\n        -petId: Integer\n    }\n\n    interface ItemRepository {\n        +findByPetId(petId: Integer): List&lt;Item&gt;\n    }\n\n    interface ItemService {\n        +save(request: ItemRequest): ItemDTO\n        +update(id: Integer, request: ItemRequest): ItemDTO\n        +deleteById(id: Integer): void\n        +findAll(): List&lt;ItemDTO&gt;\n        +findById(id: Integer): Optional&lt;ItemDTO&gt;\n        +findByPetId(petId: Integer): List&lt;ItemDTO&gt;\n    }\n\n    class ItemServiceClass implements ItemService {\n        -itemRepository: ItemRepository\n        -eventManager: EventManager\n        -petClient: PetClient\n    }\n\n    class PetClient {\n        -restTemplate: RestTemplate\n        -petServiceUrl: String\n        +getPetById(id: Integer): PetDTO\n        +getAllPets(): List&lt;PetDTO&gt;\n        +getPetName(petId: Integer): String\n    }\n\n    class ItemController {\n        -itemService: ItemService\n        -petClient: PetClient\n        +getAllItems(): ResponseEntity\n        +createItem(request): ResponseEntity\n        +updateItem(id, request): ResponseEntity\n        +deleteItem(id): ResponseEntity\n    }\n\n    Item --&gt; ItemType\n    ItemController --&gt; ItemService\n    ItemController --&gt; PetClient\n    ItemServiceClass --&gt; ItemRepository\n    ItemServiceClass --&gt; PetClient\n}\n\n&#39; =================== AUTH SERVICE ===================\npackage \&quot;auth-service\&quot; {\n    class User {\n        -id: Integer\n        -username: String\n        -password: String\n        -email: String\n        -role: Role\n    }\n\n    enum Role {\n        VISITOR\n        ADMIN\n        SELLER\n    }\n\n    interface UserRepository {\n        +findByUsername(username: String): Optional&lt;User&gt;\n    }\n\n    interface UserService {\n        +registerUser(user: User): User\n        +loginUser(username, password): User\n        +findUserByUsername(username): Optional&lt;User&gt;\n    }\n\n    class UserServiceClass implements UserService {\n        -userRepository: UserRepository\n        -passwordEncoder: BCryptPasswordEncoder\n    }\n\n    class JwtUtil {\n        -secret: String\n        +generateToken(username, role): String\n        +extractUsername(token): String\n        +extractRole(token): String\n        +isTokenValid(token): boolean\n    }\n\n    class AuthController {\n        -userService: UserService\n        -jwtUtil: JwtUtil\n        +login(request): ResponseEntity\n        +register(request): ResponseEntity\n        +validateToken(body): ResponseEntity\n    }\n\n    User --&gt; Role\n    AuthController --&gt; UserService\n    AuthController --&gt; JwtUtil\n    UserServiceClass --&gt; UserRepository\n}\n\n&#39; =================== EVENT SYSTEM ===================\npackage \&quot;Event System (shared)\&quot; {\n    interface EventListener {\n        +update(event: ResourceEvent): void\n    }\n\n    class EventManager {\n        -listeners: List&lt;EventListener&gt;\n        +subscribe(listener: EventListener): void\n        +notify(event: ResourceEvent): void\n    }\n\n    class ResourceEvent {\n        -type: String\n        -entity: String\n        -name: String\n        -payload: Object\n    }\n\n    class NotificationClient implements EventListener {\n        -restTemplate: RestTemplate\n        -notificationServiceUrl: String\n        +update(event: ResourceEvent): void\n    }\n\n    EventManager --&gt; EventListener\n    EventManager --&gt; ResourceEvent\n}\n\n&#39; =================== EXPORT SERVICE ===================\npackage \&quot;export-service\&quot; {\n    interface ExportStrategy {\n        +export(data: Object): byte[]\n    }\n\n    class JsonExportStrategy implements ExportStrategy\n    class CsvExportStrategy implements ExportStrategy\n    class XmlExportStrategy implements ExportStrategy\n\n    class ExportContext {\n        -strategy: ExportStrategy\n        +setStrategy(strategy): void\n        +export(data: Object): byte[]\n    }\n\n    class ExportService {\n        +export(data: List, format: String): byte[]\n    }\n\n    class ExportController {\n        -exportService: ExportService\n        +exportPets(format, search, sortField, sortDir): ResponseEntity\n        +exportItems(format): ResponseEntity\n    }\n\n    ExportContext --&gt; ExportStrategy\n    ExportService --&gt; ExportContext\n    ExportController --&gt; ExportService\n}\n\n&#39; =================== NOTIFICATION SERVICE ===================\npackage \&quot;notification-service\&quot; {\n    class NotificationService {\n        +sendNotification(entity, name, type): void\n        +update(event: ResourceEvent): void\n    }\n\n    class NotificationController {\n        -notificationService: NotificationService\n        +receiveNotification(request): ResponseEntity\n        +health(): ResponseEntity\n    }\n\n    NotificationController --&gt; NotificationService\n}\n\n&#39; =================== FRONTEND SERVICE ===================\npackage \&quot;frontend-service\&quot; {\n    class LoggedUser {\n        -username: String\n        -role: String\n        -token: String\n    }\n\n    class AuthClient {\n        -restTemplate: RestTemplate\n        +login(username, password): LoggedUser\n        +register(username, password, email, role): boolean\n    }\n\n    class FrontendPetController {\n        -petClient: PetClient\n        +getAllPets(): String\n        +savePet(): String\n        +updatePet(): String\n        +deletePet(): String\n    }\n\n    class FrontendItemController {\n        -itemClient: ItemClient\n        +getAllItems(): String\n        +addItem(): String\n        +updateItem(): String\n        +deleteItem(): String\n    }\n\n    class FrontendAuthController {\n        -authClient: AuthClient\n        +login(): String\n        +register(): String\n        +logout(): String\n    }\n\n    FrontendAuthController --&gt; AuthClient\n    AuthClient --&gt; LoggedUser\n}\n\n&#39; Cross-service connections\nPetServiceClass --&gt; EventManager\nItemServiceClass --&gt; EventManager\nNotificationClient --&gt; NotificationService : HTTP POST\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="W5yvFJIOyu62NXErYJGA-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="640" width="2270.06" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
